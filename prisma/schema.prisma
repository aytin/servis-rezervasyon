datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. Kullanıcı Modeli
model User {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  name         String?
  phone        String        @unique
  role         String        @default("USER") // USER veya ADMIN
  reservations Reservation[]
}

// 2. Durak Modeli (Menüden seçilecek duraklar)
model Stop {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  name         String        // Örn: "Kadıköy Evlendirme Dairesi"
  time         String        // Örn: "08:30"
  capacity     Int           // Aracın toplam kapasitesi (Örn: 16)
  reservations Reservation[]
}

// 3. Rezervasyon Modeli (İkisini birbirine bağlayan köprü)
model Reservation {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  stopId    String   @db.ObjectId
  stop      Stop     @relation(fields: [stopId], references: [id])
  date      String   // Örn: "2026-06-01" (Rezervasyon yapılan gün)
  createdAt DateTime @default(now())
}